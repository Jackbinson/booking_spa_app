NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1
APP_NAME=Spa Booking API

# Use comma separated origins for multiple clients, or * for local development.
CORS_ORIGIN=*
JSON_BODY_LIMIT=1mb

DATABASE_URL=postgres://spa_user:spa_password@localhost:55433/spa_booking
DB_POOL_MIN=2
DB_POOL_MAX=10

REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=300

# Change these before production. Production requires strong secrets.
JWT_ACCESS_SECRET=dev_access_secret_change_me_32_chars
JWT_ACCESS_EXPIRES_IN=1d
JWT_REFRESH_SECRET=dev_refresh_secret_change_me_32_chars
JWT_REFRESH_EXPIRES_IN=7d

PASSWORD_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

LOG_LEVEL=info

# OAuth 2.0 Web application client ID used to verify Google ID tokens.
GOOGLE_OAUTH_CLIENT_ID=

FIREBASE_PROJECT_ID=bookingspabe
FIREBASE_SERVICE_ACCOUNT_PATH=.secrets/firebase-service-account.json
# Copy the exact bucket name from Firebase Console > Storage. Example: your-project.firebasestorage.app
FIREBASE_STORAGE_BUCKET=bookingspabe.firebasestorage.app
FIREBASE_USE_EMULATOR=false
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
FIRESTORE_LOCATION=asia-southeast1
FIREBASE_SEED_ADMIN_EMAIL=
FIREBASE_SEED_ADMIN_PASSWORD=
